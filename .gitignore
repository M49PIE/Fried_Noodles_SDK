# ==========================================
# PYTHON ENVIRONMENT & BUILD ARTIFACTS
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage

# ==========================================
# IDE, EDITORS & OS FILES
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# LOGS & RUNTIME DATA
# ==========================================
logs/
*.log
# Runtime memory exports (ignored)
memory_field/known_objects.json
memory_field/semantic_base.json
# Configs (explicitly kept)
!configs/
!configs/*.json

# ==========================================
# DOCS & OBSIDIAN
# ==========================================
#  docs/ ON GITHUB (including .canvas and .md)
# Only ignore Obsidian's internal workspace settings.
docs/.obsidian/
docs/.trash/

# If you have a separate root Obsidian vault folder, keep it ignored:
# Obsidian/